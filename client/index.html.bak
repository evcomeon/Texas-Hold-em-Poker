<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="德州扑克 - 多人在线游戏" />
  <title>🃏 德州扑克 - 多人在线</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
  
  <!-- Google Identity Services -->
  <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body>
  <div id="app">
    <!-- Header -->
    <header class="header">
      <h1>🃏 德州扑克</h1>
      <div class="header-info">
        <span id="global-online-count" class="badge">在线: 0</span>
        <span id="hand-number" class="hidden">第 0 手</span>
        <span id="phase-badge" class="badge hidden">等待中</span>
        <span id="table-info" class="badge hidden">玩家: 0/0</span>
      </div>
    </header>

    <!-- Navigation / Top Bar -->
    <div id="user-navbar" class="user-navbar hidden">
      <div class="user-profile">
        <img id="nav-avatar" src="" alt="Avatar" class="avatar-sm" />
        <span id="nav-name">玩家名</span>
        <span class="chips-badge">💰 <span id="nav-chips">0</span></span>
      </div>
      <button id="btn-logout" class="btn btn-ghost btn-sm">退出</button>
    </div>

    <!-- Login Screen -->
    <div id="login-screen" class="screen-container">
      <div class="glass-card text-center login-card">
        <div class="start-icon">🃏</div>
        <h2>德州扑克</h2>
        <p>多人实时对战</p>
        
        <div class="login-tabs">
          <button class="login-tab active" data-tab="guest">快速体验</button>
          <button class="login-tab" data-tab="login">登录</button>
          <button class="login-tab" data-tab="register">注册</button>
        </div>
        
        <!-- Guest Login -->
        <div id="tab-guest" class="login-tab-content active">
          <div class="start-input-group">
            <input type="text" id="guest-name" placeholder="输入昵称" maxlength="10" />
          </div>
          <button id="btn-guest-login" class="btn btn-primary btn-lg w-full">游客登录</button>
        </div>
        
        <!-- Login Form -->
        <div id="tab-login" class="login-tab-content">
          <div class="start-input-group">
            <input type="text" id="login-username" placeholder="用户名" maxlength="20" />
          </div>
          <div class="start-input-group">
            <input type="password" id="login-password" placeholder="密码" maxlength="50" />
          </div>
          <button id="btn-login" class="btn btn-primary btn-lg w-full">登录</button>
          <p class="login-error hidden" id="login-error"></p>
        </div>
        
        <!-- Register Form -->
        <div id="tab-register" class="login-tab-content">
          <div class="start-input-group">
            <input type="text" id="register-username" placeholder="用户名 (2-20字符)" maxlength="20" />
          </div>
          <div class="start-input-group">
            <input type="email" id="register-email" placeholder="邮箱" maxlength="100" />
          </div>
          <div class="start-input-group">
            <input type="password" id="register-password" placeholder="密码 (至少6位)" maxlength="50" />
          </div>
          <button id="btn-register" class="btn btn-primary btn-lg w-full">注册</button>
          <p class="login-error hidden" id="register-error"></p>
        </div>
        
        <div class="divider"><span>OR</span></div>
        
        <div class="social-login">
          <div id="google-login-btn" class="google-btn-wrapper"></div>
          <button id="wallet-login-btn" class="btn btn-metamask btn-lg w-full mt-10">
            <span class="metamask-icon">🔐</span>
            <span>Web3 钱包登录</span>
          </button>
        </div>
        
        <div id="wallet-modal" class="modal hidden">
          <div class="modal-content glass-card">
            <div class="modal-header">
              <h3>选择钱包</h3>
              <button class="modal-close" id="wallet-modal-close">×</button>
            </div>
            <div class="modal-body">
              <div id="wallet-list" class="wallet-list"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lobby Screen -->
    <div id="lobby-screen" class="screen-container hidden">
      <div class="glass-card lobby-card">
        <h2>游戏大厅</h2>
        
        <div class="lobby-stats">
          <div class="stat-box">
            <span class="stat-label">当前在线玩家</span>
            <span id="lobby-online-count" class="stat-value text-accent">--</span>
          </div>
          <div class="stat-box clickable" id="btn-profile">
            <span class="stat-label">我的筹码</span>
            <span id="lobby-my-chips" class="stat-value text-gold">10,000</span>
          </div>
          <div class="stat-box clickable" id="btn-leaderboard">
            <span class="stat-label">🏆 排行榜</span>
            <span class="stat-value text-accent">查看</span>
          </div>
        </div>

        <div class="stake-level-selector">
          <h4>选择盲注级别</h4>
          <div class="stake-options">
            <button class="stake-option" data-level="low">
              <span class="stake-name">低注桌</span>
              <span class="stake-blinds">5/10</span>
            </button>
            <button class="stake-option active" data-level="medium">
              <span class="stake-name">中注桌</span>
              <span class="stake-blinds">10/20</span>
            </button>
            <button class="stake-option" data-level="high">
              <span class="stake-name">高注桌</span>
              <span class="stake-blinds">25/50</span>
            </button>
          </div>
        </div>
        
        <div class="queue-status hidden" id="queue-status">
          <div class="spinner"></div>
          <p>正在匹配对手... (<span id="queue-count">1</span>/2)</p>
          <button id="btn-cancel-match" class="btn btn-danger mt-10">取消匹配</button>
        </div>

        <button id="btn-find-match" class="btn btn-primary btn-lg pulse-btn">开始匹配</button>
      </div>
    </div>

    <!-- Profile Panel -->
    <div id="profile-panel" class="profile-panel hidden">
      <div class="profile-content">
        <div class="profile-header">
          <img id="profile-avatar" src="" alt="Avatar" class="profile-avatar" />
          <div class="profile-info">
            <h3 id="profile-username">用户名</h3>
            <p id="profile-email" class="text-muted"></p>
          </div>
          <button class="btn-close" id="profile-close">✕</button>
        </div>
        <div class="profile-stats">
          <div class="profile-stat">
            <span class="profile-stat-value text-gold" id="profile-chips">10,000</span>
            <span class="profile-stat-label">筹码</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-value" id="profile-level">1</span>
            <span class="profile-stat-label">等级</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-value" id="profile-games">0</span>
            <span class="profile-stat-label">场次</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-value text-accent" id="profile-wins">0</span>
            <span class="profile-stat-label">胜场</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-value" id="profile-winrate">0%</span>
            <span class="profile-stat-label">胜率</span>
          </div>
        </div>
        <div class="profile-wallet" id="profile-wallet-section">
          <p class="text-muted text-sm">钱包地址: <span id="profile-wallet-address">未绑定</span></p>
        </div>
        <div class="profile-token-section">
          <div class="profile-token-header">
            <span class="text-muted text-sm">API Token (JWT)</span>
            <button class="btn btn-sm btn-ghost" id="btn-copy-token">📋 复制</button>
          </div>
          <div class="profile-token-value" id="profile-token-display">-</div>
        </div>
        <div class="profile-actions">
          <button id="btn-recharge" class="btn btn-accent w-full mb-10">💰 充值筹码</button>
          <button id="btn-logout-profile" class="btn btn-danger w-full">退出登录</button>
        </div>
      </div>
    </div>

    <!-- Leaderboard Panel -->
    <div id="leaderboard-panel" class="leaderboard-panel hidden">
      <div class="leaderboard-content">
        <div class="leaderboard-header">
          <h3>🏆 排行榜</h3>
          <button class="btn-close" id="leaderboard-close">✕</button>
        </div>
        
        <div class="leaderboard-tabs">
          <button class="leaderboard-tab active" data-type="chips">筹码榜</button>
          <button class="leaderboard-tab" data-type="winrate">胜率榜</button>
        </div>
        
        <div class="leaderboard-list" id="leaderboard-list">
          <div class="leaderboard-loading">加载中...</div>
        </div>
      </div>
    </div>

    <!-- Recharge Panel -->
    <div id="recharge-panel" class="recharge-panel hidden">
      <div class="recharge-content">
        <div class="recharge-header">
          <h3>💰 充值筹码</h3>
          <button class="btn-close" id="recharge-close">✕</button>
        </div>
        
        <div class="recharge-info">
          <div class="recharge-rate">
            <span class="rate-label">汇率</span>
            <span class="rate-value" id="recharge-rate">1 USDT/USDC = 10,000 筹码</span>
          </div>
          <div class="recharge-wallet">
            <span class="wallet-label">充值地址</span>
            <span class="wallet-value" id="recharge-wallet-address">-</span>
            <button class="btn btn-sm btn-ghost" id="btn-copy-address">复制</button>
          </div>
        </div>

        <div class="recharge-form">
          <div class="form-group">
            <label>选择代币</label>
            <div class="token-selector">
              <button class="token-option active" data-token="USDT">USDT</button>
              <button class="token-option" data-token="USDC">USDC</button>
            </div>
          </div>
          
          <div class="form-group">
            <label>充值数量</label>
            <div class="amount-input">
              <input type="number" id="recharge-amount" placeholder="输入数量" min="1" step="0.01" />
              <span class="amount-token" id="amount-token-label">USDT</span>
            </div>
            <p class="amount-hint">最小充值: <span id="min-amount">1</span> USDT/USDC</p>
          </div>
          
          <div class="form-group">
            <label>可获得筹码</label>
            <div class="chips-preview">
              <span id="chips-preview">0</span> 筹码
            </div>
          </div>
          
          <button id="btn-create-order" class="btn btn-primary btn-lg w-full" disabled>
            创建充值订单
          </button>
        </div>

        <div class="recharge-orders">
          <h4>充值记录</h4>
          <div id="recharge-history" class="recharge-history"></div>
        </div>
      </div>
    </div>

    <!-- Order Status Panel -->
    <div id="order-panel" class="order-panel hidden">
      <div class="order-content">
        <div class="order-header">
          <h3>订单详情</h3>
          <button class="btn-close" id="order-close">✕</button>
        </div>
        
        <div class="order-info">
          <div class="order-row">
            <span class="order-label">订单号</span>
            <span class="order-value" id="order-no">-</span>
          </div>
          <div class="order-row">
            <span class="order-label">金额</span>
            <span class="order-value" id="order-amount">-</span>
          </div>
          <div class="order-row">
            <span class="order-label">筹码</span>
            <span class="order-value" id="order-chips">-</span>
          </div>
          <div class="order-row">
            <span class="order-label">状态</span>
            <span class="order-value" id="order-status">-</span>
          </div>
        </div>
        
        <div class="order-tx" id="order-tx-section">
          <p class="text-muted text-sm">交易已提交，请等待区块链确认...</p>
          <div class="tx-hash">
            <span id="order-tx-hash">-</span>
          </div>
        </div>
        
        <div class="order-pending" id="order-pending-section">
          <p class="text-muted">请在钱包中完成转账</p>
          <div class="transfer-info">
            <p>转账地址: <span id="order-to-address">-</span></p>
            <p>转账数量: <span id="order-token-amount">-</span></p>
          </div>
          <div class="form-group mt-10">
            <label>交易哈希 (转账完成后填写)</label>
            <input type="text" id="tx-hash-input" placeholder="0x..." />
          </div>
          <button id="btn-submit-tx" class="btn btn-primary w-full">提交交易哈希</button>
        </div>
        
        <button id="btn-refresh-order" class="btn btn-ghost w-full mt-10">刷新状态</button>
      </div>
    </div>

    <!-- Game Area -->
    <div id="game-area" class="game-area hidden">
      <!-- Spectator Banner -->
      <div id="spectator-banner" class="spectator-banner hidden">
        <span>👁️ 您正在观战</span>
        <span id="spectator-count">观战者: 0</span>
      </div>
      <!-- Poker Table -->
      <div class="table-container">
        <div class="poker-table">
          <!-- Opponent Seats (Supports up to 7 opponents for 8 max players) -->
          <div class="seats">
            <div class="seat seat-left-2" id="seat-5"></div>
            <div class="seat seat-left-1" id="seat-6"></div>
            <div class="seat seat-top-left" id="seat-1"></div>
            <div class="seat seat-top" id="seat-2"></div>
            <div class="seat seat-top-right" id="seat-3"></div>
            <div class="seat seat-right-1" id="seat-7"></div>
            <div class="seat seat-right-2" id="seat-4"></div>
          </div>

          <!-- Community Cards -->
          <div class="community-area">
            <div class="community-cards" id="community-cards"></div>
            <div class="pot-display">
              <span class="pot-label">底池</span>
              <span class="pot-amount" id="pot-amount">0</span>
            </div>
          </div>

          <!-- Player Seat -->
          <div class="player-area">
            <div class="seat seat-bottom" id="seat-0"></div>
          </div>
        </div>
      </div>

      <!-- Action Bar -->
      <div class="action-bar" id="action-bar">
        <div class="timer-display hidden" id="timer-display">
          <div class="timer-bar">
            <div class="timer-progress" id="timer-progress"></div>
          </div>
          <span class="timer-text" id="timer-text">30s</span>
        </div>
        <div class="action-buttons" id="action-buttons"></div>
        <div class="raise-controls hidden" id="raise-controls">
          <input type="range" id="raise-slider" min="0" max="1000" step="10" />
          <div class="raise-display">
            <span id="raise-value">0</span>
            <button id="btn-confirm-raise" class="btn btn-accent">确认加注</button>
          </div>
        </div>
      </div>

      <!-- Last Action Notification -->
      <div class="notification hidden" id="notification"></div>
    </div>

    <!-- History Panel -->
    <div class="history-toggle hidden" id="history-toggle">📋</div>
    <div class="history-panel hidden" id="history-panel">
      <div class="history-header">
        <h3>对局记录</h3>
        <button class="btn-close" id="history-close">✕</button>
      </div>
      <div class="history-list" id="history-list"></div>
    </div>

    <!-- Chat Panel -->
    <div class="chat-toggle hidden" id="chat-toggle">💬</div>
    <div class="chat-panel hidden" id="chat-panel">
      <div class="chat-header">
        <h3>聊天</h3>
        <button class="btn-close" id="chat-close">✕</button>
      </div>
      <div class="chat-messages" id="chat-messages"></div>
      <div class="chat-input-area">
        <input type="text" id="chat-input" placeholder="输入消息..." maxlength="200" />
        <button id="btn-send-chat" class="btn btn-primary btn-sm">发送</button>
      </div>
    </div>

    <!-- Game Log -->
    <div class="game-log" id="game-log"></div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="wallet.js"></script>
  <script type="module" src="main.js"></script>
</body>
</html>
