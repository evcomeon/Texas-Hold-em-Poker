# ============================================================
# Recharge Service Configuration
# ============================================================

# Server
PORT=3002
NODE_ENV=development

# Database (连接主项目数据库)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/poker_game

# Blockchain Configuration
# Ethereum Network (mainnet, goerli, sepolia, polygon, bsc)
ETHEREUM_NETWORK=mainnet
# Or use custom RPC URL
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Recharge Wallet (接收充值的钱包地址)
RECHARGE_WALLET_ADDRESS=0xYourWalletAddressHere
RECHARGE_WALLET_PRIVATE_KEY=your_private_key_here

# Token Contract Addresses (Mainnet)
USDT_CONTRACT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDC_CONTRACT_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Token Contract Addresses (Testnet - Goerli/Sepolia)
# USDT_CONTRACT_ADDRESS=0x...
# USDC_CONTRACT_ADDRESS=0x...

# Chips Exchange Rate (可配置的汇率)
# 1 USDT/USDC = ? chips
CHIPS_PER_USD=10000

# Minimum recharge amount (in USD, minimum 1)
MIN_RECHARGE_AMOUNT=1

# Maximum recharge amount (in USD, 0 = unlimited)
MAX_RECHARGE_AMOUNT=0

# Transaction confirmation blocks
CONFIRMATION_BLOCKS=3

# Polling interval (milliseconds)
POLLING_INTERVAL=5000

# API Security
API_SECRET_KEY=your_api_secret_key_here

# Logging
LOG_LEVEL=info
